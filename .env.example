# Copy this file to `.env` and fill in your own Supabase project values.
# The anon / publishable key is safe to expose in the browser — access is
# restricted by Row Level Security (see schema.sql). Find both values in your
# Supabase dashboard under: Project Settings → API.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key
